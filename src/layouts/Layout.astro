---
import GradientBg from '../components/GradientBg.astro';
interface Props {
	title: string;
}

const {title = "Comissions"} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>{title}</title>
		<meta name="generator" content={Astro.generator}/>
		<meta name="description" content="Comissions Rooh ayko" />
		<meta name="keywords" content="comissions, pixel art, art, animations, gif, rooh_ayko"/>
		<meta name="authors" content="DatBrian"/>
	</head>
	<body>
		<div id="mask" class="min-h-screen w-full">
			<GradientBg />
			<div class="relative z-2">
				<slot />
			</div>
		</div>
	</body>
</html>

<style is:global>
	@import "tailwindcss";
	@import "tailwind-animations";
	@font-face {
		font-family: 'pixel';
		src: url('/fonts/pixel.ttf') format('truetype');
		font-weight: normal;
		font-style: swap;
	}

	h1,h2, a{
		font-family: 'pixel', sans-serif;
	}
</style>

<style>

	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}

	#mask{
		background-image: url('/images/main-bg.jpg');
		background-size: cover;
		background-position: center;
		background-repeat: no-repeat;
	}

</style>
